generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  slug  String @unique
  tips  Tip[]
}

model Tip {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  content    String
  createdAt  DateTime @default(now())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
}